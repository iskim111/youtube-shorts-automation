# App
APP_ENV=development
APP_NAME=shorts-automation
DEFAULT_OPERATION_MODE=semi_auto
DAILY_UPLOAD_CAP=5
DEFAULT_PUBLISH_HOURS=18,19,20,21

# Database (PostgreSQL — Docker Compose 사용 시)
DATABASE_URL=postgresql+asyncpg://shorts:shorts@localhost:5432/shorts_automation
# 로컬 빠른 테스트: sqlite+aiosqlite:///./data/shorts.db

# Dev: true면 시작 시 테이블 자동 생성 (Alembic 대신)
CREATE_TABLES_ON_STARTUP=true

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=amqp://shorts:shorts@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage (local: minio)
STORAGE_BACKEND=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=shorts-assets
STORAGE_REGION=us-east-1

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRE_MIN=15
JWT_REFRESH_EXPIRE_DAYS=7

# Frontend (OAuth 콜백 후 리다이렉트) — 포트 3000 사용 안 함
FRONTEND_PORT=3001
FRONTEND_BASE_URL=http://localhost:3001

# External APIs (MVP 이후 설정)
OPENAI_API_KEY=
GCP_PROJECT_ID=

# Asset strategy: free_only | hybrid | ai_preferred
# free_only  — Pexels/Pixabay 무료 스톡만 (기본)
# hybrid     — AI 1~N장면 + 나머지 스톡 (OPENAI_API_KEY 등 필요)
# ai_preferred — AI 우선, 실패 시 스톡 fallback
ASSET_STRATEGY=free_only
AI_IMAGE_PROVIDER=openai
AI_VIDEO_PROVIDER=none
AI_MAX_SCENES_PER_JOB=1
RUNWAY_API_KEY=
LUMA_API_KEY=

# YouTube OAuth — Google Cloud Console > APIs & Services > Credentials
# Redirect URI: http://localhost:8000/api/v1/channels/oauth/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/channels/oauth/callback
PEXELS_API_KEY=
PIXABAY_API_KEY=

# FFmpeg (미설정 시 tools/ffmpeg/ 또는 PATH 자동 탐색)
FFMPEG_PATH=

# Ops
SLACK_WEBHOOK_URL=
CORS_ORIGINS=http://localhost:3001
DATA_DIR=./data
PILOT_DRY_RUN_UPLOAD=true
PILOT_DEFAULT_PRIVACY=private
USE_CELERY=false
AUTH_ENABLED=false
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=admin1234

# Stock APIs (Beta)
PEXELS_API_KEY=
PIXABAY_API_KEY=
